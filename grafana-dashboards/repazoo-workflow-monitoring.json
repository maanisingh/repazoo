{
  "dashboard": {
    "id": null,
    "title": "RepAZoo Workflow Monitoring",
    "tags": ["repazoo", "temporal", "workflows", "reputation"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Active Workflows",
        "type": "stat",
        "targets": [
          {
            "expr": "count(temporal_workflow_status{status=\"running\"})",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "green", "value": 1}
              ]
            }
          }
        },
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Total Mentions Processed",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(increase(mentions_processed_total[24h]))",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "unit": "short"
          }
        },
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0}
      },
      {
        "id": 3,
        "title": "Average Reputation Score",
        "type": "stat",
        "targets": [
          {
            "expr": "avg(reputation_score)",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 30},
                {"color": "green", "value": 70}
              ]
            },
            "min": 0,
            "max": 100,
            "unit": "percent"
          }
        },
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0}
      },
      {
        "id": 4,
        "title": "Active Crisis Events",
        "type": "stat",
        "targets": [
          {
            "expr": "count(crisis_events{status=\"active\"})",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 1},
                {"color": "red", "value": 3}
              ]
            }
          }
        },
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0}
      },
      {
        "id": 5,
        "title": "Workflow Execution Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(temporal_workflow_executions_total[5m])",
            "refId": "A",
            "legendFormat": "Executions/sec"
          },
          {
            "expr": "rate(temporal_workflow_failures_total[5m])",
            "refId": "B",
            "legendFormat": "Failures/sec"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
        "yAxes": [
          {
            "label": "Rate",
            "min": 0
          }
        ]
      },
      {
        "id": 6,
        "title": "Sentiment Distribution",
        "type": "piechart",
        "targets": [
          {
            "expr": "count by (sentiment) (mentions{sentiment!=\"\"})",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
        "options": {
          "legend": {
            "displayMode": "table",
            "placement": "right"
          }
        }
      },
      {
        "id": 7,
        "title": "Source Performance",
        "type": "table",
        "targets": [
          {
            "expr": "sum by (source_type) (increase(mentions_scraped_total[1h]))",
            "refId": "A",
            "format": "table"
          }
        ],
        "gridPos": {"h": 6, "w": 8, "x": 0, "y": 12},
        "fieldConfig": {
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "Value"},
              "properties": [
                {"id": "displayName", "value": "Mentions/Hour"}
              ]
            }
          ]
        }
      },
      {
        "id": 8,
        "title": "Workflow Duration",
        "type": "histogram",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(temporal_workflow_duration_seconds_bucket[5m]))",
            "refId": "A",
            "legendFormat": "95th percentile"
          },
          {
            "expr": "histogram_quantile(0.50, rate(temporal_workflow_duration_seconds_bucket[5m]))",
            "refId": "B",
            "legendFormat": "50th percentile"
          }
        ],
        "gridPos": {"h": 6, "w": 8, "x": 8, "y": 12},
        "yAxes": [
          {
            "label": "Duration (seconds)",
            "min": 0
          }
        ]
      },
      {
        "id": 9,
        "title": "Error Rate by Workflow Type",
        "type": "bargauge",
        "targets": [
          {
            "expr": "rate(temporal_workflow_failures_total[1h]) / rate(temporal_workflow_executions_total[1h]) * 100",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 6, "w": 8, "x": 16, "y": 12},
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "max": 100,
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 5},
                {"color": "red", "value": 10}
              ]
            }
          }
        }
      },
      {
        "id": 10,
        "title": "Recent Alerts",
        "type": "logs",
        "targets": [
          {
            "expr": "{job=\"repazoo\"} |= \"ALERT\"",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 18},
        "options": {
          "showTime": true,
          "showLabels": true,
          "sortOrder": "Descending"
        }
      },
      {
        "id": 11,
        "title": "Database Performance",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(postgresql_queries_total[5m])",
            "refId": "A",
            "legendFormat": "Queries/sec"
          },
          {
            "expr": "postgresql_connections_active",
            "refId": "B",
            "legendFormat": "Active Connections"
          }
        ],
        "gridPos": {"h": 6, "w": 12, "x": 0, "y": 26},
        "yAxes": [
          {
            "label": "Count",
            "min": 0
          }
        ]
      },
      {
        "id": 12,
        "title": "System Resources",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(process_cpu_seconds_total[5m]) * 100",
            "refId": "A",
            "legendFormat": "CPU Usage %"
          },
          {
            "expr": "process_resident_memory_bytes / 1024 / 1024",
            "refId": "B",
            "legendFormat": "Memory MB"
          }
        ],
        "gridPos": {"h": 6, "w": 12, "x": 12, "y": 26},
        "yAxes": [
          {
            "label": "Usage",
            "min": 0
          }
        ]
      },
      {
        "id": 13,
        "title": "Reputation Score Trends",
        "type": "graph",
        "targets": [
          {
            "expr": "avg_over_time(reputation_score[1h])",
            "refId": "A",
            "legendFormat": "Average Score"
          }
        ],
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 32},
        "yAxes": [
          {
            "label": "Score",
            "min": 0,
            "max": 100
          }
        ],
        "alert": {
          "conditions": [
            {
              "evaluator": {
                "params": [30],
                "type": "lt"
              },
              "operator": {
                "type": "and"
              },
              "query": {
                "params": ["A", "5m", "now"]
              },
              "reducer": {
                "params": [],
                "type": "avg"
              },
              "type": "query"
            }
          ],
          "executionErrorState": "alerting",
          "for": "5m",
          "frequency": "10s",
          "handler": 1,
          "name": "Low Reputation Score Alert",
          "noDataState": "no_data",
          "notifications": []
        }
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
    },
    "refresh": "30s",
    "schemaVersion": 27,
    "version": 1,
    "links": [
      {
        "title": "RepAZoo Dashboard",
        "url": "https://dash.repazoo.com",
        "type": "link"
      },
      {
        "title": "Temporal UI",
        "url": "https://ai.repazoo.com",
        "type": "link"
      }
    ]
  }
}